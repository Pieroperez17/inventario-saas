# ==========================================================================
# Variables de entorno del backend — Sistema de Inventario SaaS
# Copia este archivo como .env y ajusta los valores. NUNCA subas .env al repo.
# ==========================================================================

# Entorno de ejecución: development | production | test
NODE_ENV=development

# Puerto en el que escucha la API
PORT=4000

# Cadena de conexión a PostgreSQL.
#  - En local (PostgreSQL instalado): host=localhost
#  - En Docker (docker-compose): host=db  (nombre del servicio)
DATABASE_URL="postgresql://inventario:inventario@localhost:5432/inventario_db?schema=public"

# Secretos JWT (¡cámbialos en producción por cadenas largas y aleatorias!)
JWT_ACCESO_SECRETO="define-un-secreto-largo-y-aleatorio-para-acceso"
JWT_ACCESO_EXPIRA="15m"
JWT_REFRESH_SECRETO="define-un-secreto-largo-y-aleatorio-para-refresh"
JWT_REFRESH_EXPIRA="7d"

# Orígenes permitidos por CORS (separados por coma)
CORS_ORIGEN="http://localhost:5173"

# Zona horaria por defecto del sistema
ZONA_HORARIA="America/Lima"

# Límite de peticiones por ventana (rate limiting)
LIMITE_PETICIONES=300
LIMITE_VENTANA_MINUTOS=15
